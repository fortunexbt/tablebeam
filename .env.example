# Vector Store Configuration
# Options: "chroma" (default) or "pinecone"
VECTOR_STORE_TYPE=chroma

# ChromaDB Configuration (default vector store)
# No additional configuration needed for ChromaDB

# Pinecone Configuration (alternative vector store)
# Required when VECTOR_STORE_TYPE=pinecone
PINECONE_API_KEY=your-pinecone-api-key-here

# Optional Pinecone settings
PINECONE_INDEX_NAME=client-tracker
PINECONE_NAMESPACE=production
PINECONE_REGION=us-east-1

# Embedding Model Configuration
EMBEDDING_MODEL=mxbai-embed-large

# Application Settings
LOG_LEVEL=INFO